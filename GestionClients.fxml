<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="CtrlGestionClients"
            prefWidth="900" prefHeight="600">

    <top>
        <VBox spacing="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Label text="Gestion des Clients" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <HBox spacing="10">
                <Label text="Rechercher :"/>
                <TextField fx:id="champRecherche" promptText="Nom, prénom ou email..." prefWidth="250"/>
                <Button text="Rechercher"   onAction="#rechercherClient"/>
                <Button text="Réinitialiser" onAction="#reinitialiser"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <VBox spacing="5" prefWidth="320">
                <Label text="Liste des clients" style="-fx-font-weight: bold;"/>
                <TableView fx:id="tableClients" prefHeight="450" onMouseClicked="#selectionnerClient">
                    <columns>
                        <TableColumn fx:id="colNom"    text="Nom"    prefWidth="100"/>
                        <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="100"/>
                        <TableColumn fx:id="colEmail"  text="Email"  prefWidth="160"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10" prefWidth="430">
                <Label text="Détail / Création" style="-fx-font-weight: bold;"/>

                <GridPane hgap="10" vgap="8">
                    <Label text="ID :"              GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="champId"      GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="220"/>

                    <Label text="Nom :"             GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="champNom"     GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Prénom :"          GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="champPrenom"  GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Email :"           GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="champEmail"   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Numéro :"          GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="champNumero"  GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <Label text="Rue :"             GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <TextField fx:id="champRue"     GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                    <Label text="Ville :"           GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                    <TextField fx:id="champVille"   GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                    <Label text="Code postal :"         GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                    <TextField fx:id="champCodePostal"  GridPane.rowIndex="7" GridPane.columnIndex="1"/>
                </GridPane>

                <Label text="Billets achetés :" style="-fx-font-weight: bold;"/>
                <ListView fx:id="listeBillets" prefHeight="100"/>

                <HBox spacing="10">
                    <Button text="Créer"      onAction="#creerClient"/>
                    <Button text="Modifier"   onAction="#modifierClient"/>
                    <Button text="Supprimer"  onAction="#supprimerClient"/>
                    <Button text="Rembourser" onAction="#rembourserBillets"/>
                </HBox>

                <Label fx:id="labelMessage" style="-fx-text-fill: red;"/>
            </VBox>
        </HBox>
    </center>

</BorderPane>
